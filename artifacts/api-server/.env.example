# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Railway Postgres, Neon, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Admin dashboard ──────────────────────────────────────────────────────────
# Secret key that gates the admin API routes (/api/admin/*)
ADMIN_SECRET=change-me-to-a-long-random-string

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# "From" address for outbound estimate/contact emails (must be verified in Resend)
ESTIMATOR_FROM_EMAIL=noreply@spconstructiondfw.com

# ─── Google Maps (server-side only) ───────────────────────────────────────────
# Used for the Solar API roof-area lookup. Key must have the Solar API enabled.
# NEVER expose this key to the browser.
GOOGLE_MAPS_SERVER_API_KEY=AIza...

# ─── Cloudflare R2 (object storage) ──────────────────────────────────────────
# Account ID — found in the Cloudflare dashboard sidebar.
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# R2 API token credentials (create an API token with Object Read & Write)
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The name of the R2 bucket
R2_BUCKET_NAME=sp-construction-media
# Public URL for the bucket (set up a custom domain or use the R2.dev subdomain)
# Used for direct public asset links if needed — not required for proxied serving.
R2_PUBLIC_URL=https://media.spconstructiondfw.com

# ─── Object storage path config ───────────────────────────────────────────────
# Virtual path prefix for private/uploaded objects: /<bucket>/<key-prefix>
PRIVATE_OBJECT_DIR=/sp-construction-media/uploads
# Comma-separated virtual path prefixes for public/served objects
PUBLIC_OBJECT_SEARCH_PATHS=/sp-construction-media/public

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Extra origins to allow beyond the defaults (spconstructiondfw.com, *.pages.dev,
# localhost). Comma-separated. Leave blank if you only use the default domains.
ALLOWED_ORIGINS=
